# Database - Azure SQL connection string
# For local development with SQLite, leave this empty or comment out
DATABASE_URL=mssql+pyodbc://username:password@server.database.windows.net:1433/dbname?driver=ODBC+Driver+17+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no&Connection+Timeout=30

# JWT Configuration
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256

# CORS - comma separated origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.azurestaticapps.net

# SendGrid (optional - falls back to console logging if not set)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@atomquest.com
